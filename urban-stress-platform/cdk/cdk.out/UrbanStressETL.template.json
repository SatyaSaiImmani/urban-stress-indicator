   "Properties": {
    "DefinitionString": "{\"Comment\": \"Urban Stress ETL Pipeline\", \"StartAt\": \"RunBronzeETL\", \"States\": {\"RunBronzeETL\": {\"Type\": \"Task\", \"Resource\": \"arn:aws:states:::glue:startJobRun.sync\", \"Parameters\": {\"JobName\": \"urban-stress-bronzeetl\"}, \"ResultPath\": null, \"Next\": \"RunSilverETL\"}, \"RunSilverETL\": {\"Type\": \"Task\", \"Resource\": \"arn:aws:states:::glue:startJobRun.sync\", \"Parameters\": {\"JobName\": \"urban-stress-silveretl\"}, \"ResultPath\": null, \"Next\": \"RunSignalScoring\"}, \"RunSignalScoring\": {\"Type\": \"Task\", \"Resource\": \"arn:aws:states:::glue:startJobRun.sync\", \"Parameters\": {\"JobName\": \"urban-stress-signalscore\"}, \"ResultPath\": null, \"Next\": \"RunCompositeScore\"}, \"RunCompositeScore\": {\"Type\": \"Task\", \"Resource\": \"arn:aws:states:::glue:startJobRun.sync\", \"Parameters\": {\"JobName\": \"urban-stress-compositescore\"}, \"ResultPath\": null, \"Next\": \"RunGdeltCollector\"}, \"RunGdeltCollector\": {\"Type\": \"Task\", \"Resource\": \"arn:aws:states:::glue:startJobRun.sync\", \"Parameters\": {\"JobName\": \"urban-stress-gdeltcollector\"}, \"ResultPath\": null, \"End\": true}}}",
    "RoleArn": "arn:aws:iam::677542194461:role/LabRole",
    "StateMachineName": "urban-stress-etl-pipeline"
   },
