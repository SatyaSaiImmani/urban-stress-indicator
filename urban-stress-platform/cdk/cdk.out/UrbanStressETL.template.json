  },
  "PipelineStateChangeRule": {
   "Type": "AWS::Events::Rule",
   "Properties": {
    "EventPattern": {
     "source": [
      "aws.states"
     ],
     "detail-type": [
      "Step Functions Execution Status Change"
     ],
     "detail": {
      "stateMachineArn": [
       "arn:aws:states:us-east-1:677542194461:stateMachine:urban-stress-etl-pipeline"
      ],
      "status": [
       "SUCCEEDED",
       "FAILED",
       "TIMED_OUT",
       "ABORTED"
      ]
     }
    },
    "Name": "urban-stress-pipeline-state-change",
    "State": "ENABLED",
    "Targets": [
     {
      "Arn": "arn:aws:lambda:us-east-1:677542194461:function:urban-stress-log-run",
      "Id": "LogPipelineRun"
     }
    ]
   },
   "DependsOn": [
    "ETLPipeline",
    "LogRun"
   ],
   "Metadata": {
    "aws:cdk:path": "UrbanStressETL/PipelineStateChangeRule"
   }
  },
  "LogRunEventPermission": {
   "Type": "AWS::Lambda::Permission",
   "Properties": {
    "Action": "lambda:InvokeFunction",
    "FunctionName": "urban-stress-log-run",
    "Principal": "events.amazonaws.com",
    "SourceArn": "arn:aws:events:us-east-1:677542194461:rule/urban-stress-pipeline-state-change"
   },
   "DependsOn": [
    "LogRun",
    "PipelineStateChangeRule"
   ],
   "Metadata": {
    "aws:cdk:path": "UrbanStressETL/LogRunEventPermission"
   }
  },
  "ETLFailedAlarm": {
   "Type": "AWS::CloudWatch::Alarm",
   "Properties": {
    "AlarmDescription": "One or more urban-stress-etl-pipeline executions failed. Check Step Functions console for the failing Glue job.",
    "AlarmName": "urban-stress-etl-pipeline-failed",
    "ComparisonOperator": "GreaterThanOrEqualToThreshold",
    "Dimensions": [
     {
      "Name": "StateMachineArn",
      "Value": "arn:aws:states:us-east-1:677542194461:stateMachine:urban-stress-etl-pipeline"
     }
    ],
    "EvaluationPeriods": 1,
    "MetricName": "ExecutionsFailed",
    "Namespace": "AWS/States",
    "Period": 300,
    "Statistic": "Sum",
    "Threshold": 1,
    "TreatMissingData": "notBreaching"
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressETL/ETLFailedAlarm"
   }
  },
