{
 "Resources": {
  "DashboardLogGroup": {
   "Type": "AWS::Logs::LogGroup",
   "Properties": {
    "LogGroupName": "/ecs/urban-stress-dashboard",
    "RetentionInDays": 30
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardLogGroup"
   }
  },
  "AlbSg": {
   "Type": "AWS::EC2::SecurityGroup",
   "Properties": {
    "GroupDescription": "ALB - allow HTTP from anywhere",
    "SecurityGroupIngress": [
     {
      "CidrIp": "0.0.0.0/0",
      "FromPort": 80,
      "IpProtocol": "tcp",
      "ToPort": 80
     }
    ],
    "VpcId": {
     "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpc2AE86FA65E024251"
    }
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/AlbSg"
   }
  },
  "TaskSg": {
   "Type": "AWS::EC2::SecurityGroup",
   "Properties": {
    "GroupDescription": "ECS task - allow 8501 from ALB",
    "SecurityGroupIngress": [
     {
      "FromPort": 8501,
      "IpProtocol": "tcp",
      "SourceSecurityGroupId": {
       "Fn::GetAtt": [
        "AlbSg",
        "GroupId"
       ]
      },
      "ToPort": 8501
     }
    ],
    "VpcId": {
     "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpc2AE86FA65E024251"
    }
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/TaskSg"
   }
  },
  "DashboardAlb": {
   "Type": "AWS::ElasticLoadBalancingV2::LoadBalancer",
   "Properties": {
    "Name": "urban-stress-alb",
    "Scheme": "internet-facing",
    "SecurityGroups": [
     {
      "Fn::GetAtt": [
       "AlbSg",
       "GroupId"
      ]
     }
    ],
    "Subnets": [
     {
      "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpcPublicSubnet1SubnetB3F9C79BB7FB4087"
     },
     {
      "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpcPublicSubnet2Subnet9557769E4F7FA592"
     }
    ],
    "Type": "application"
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardAlb"
   }
  },
  "DashboardTg": {
   "Type": "AWS::ElasticLoadBalancingV2::TargetGroup",
   "Properties": {
    "HealthCheckIntervalSeconds": 30,
    "HealthCheckPath": "/_stcore/health",
    "HealthCheckProtocol": "HTTP",
    "HealthyThresholdCount": 2,
    "Matcher": {
     "HttpCode": "200"
    },
    "Name": "urban-stress-tg",
    "Port": 8501,
    "Protocol": "HTTP",
    "TargetType": "ip",
    "UnhealthyThresholdCount": 3,
    "VpcId": {
     "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpc2AE86FA65E024251"
    }
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardTg"
   }
  },
  "DashboardListener": {
   "Type": "AWS::ElasticLoadBalancingV2::Listener",
   "Properties": {
    "DefaultActions": [
     {
      "TargetGroupArn": {
       "Ref": "DashboardTg"
      },
      "Type": "forward"
     }
    ],
    "LoadBalancerArn": {
     "Ref": "DashboardAlb"
    },
    "Port": 80,
    "Protocol": "HTTP"
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardListener"
   }
  },
  "DashboardCluster": {
   "Type": "AWS::ECS::Cluster",
   "Properties": {
    "ClusterName": "urban-stress-cluster"
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardCluster"
   }
  },
  "DashboardTaskDef": {
   "Type": "AWS::ECS::TaskDefinition",
   "Properties": {
    "ContainerDefinitions": [
     {
      "Environment": [
       {
        "Name": "DB_HOST",
        "Value": {
         "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputFnGetAttUrbanStressDb57C845BCEndpointAddress5247EDA7"
        }
       },
       {
        "Name": "DB_PORT",
        "Value": "5432"
       },
       {
        "Name": "DB_NAME",
        "Value": "postgres"
       },
       {
        "Name": "DB_SECRET_ARN",
        "Value": {
         "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefDbSecret685A0FA57881E1C6"
        }
       },
       {
        "Name": "DB_USER",
        "Value": "postgres"
       }
      ],
      "Essential": true,
      "Image": "677542194461.dkr.ecr.us-east-1.amazonaws.com/urban-stress-dashboard:latest",
      "LogConfiguration": {
       "LogDriver": "awslogs",
       "Options": {
        "awslogs-group": "/ecs/urban-stress-dashboard",
        "awslogs-region": "us-east-1",
        "awslogs-stream-prefix": "ecs"
       }
      },
      "Name": "dashboard",
      "PortMappings": [
       {
        "ContainerPort": 8501,
        "Protocol": "tcp"
       }
      ],
      "Secrets": [
       {
        "Name": "DB_PASSWORD",
        "ValueFrom": {
         "Fn::Join": [
          "",
          [
           {
            "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefDbSecret685A0FA57881E1C6"
           },
           ":password::"
          ]
         ]
        }
       }
      ]
     }
    ],
    "Cpu": "256",
    "ExecutionRoleArn": "arn:aws:iam::677542194461:role/LabRole",
    "Family": "urban-stress-dashboard",
    "Memory": "512",
    "NetworkMode": "awsvpc",
    "RequiresCompatibilities": [
     "FARGATE"
    ],
    "TaskRoleArn": "arn:aws:iam::677542194461:role/LabRole"
   },
   "DependsOn": [
    "DashboardLogGroup"
   ],
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardTaskDef"
   }
  },
  "DashboardService": {
   "Type": "AWS::ECS::Service",
   "Properties": {
    "Cluster": {
     "Ref": "DashboardCluster"
    },
    "DeploymentConfiguration": {
     "MaximumPercent": 200,
     "MinimumHealthyPercent": 0
    },
    "DesiredCount": 1,
    "LaunchType": "FARGATE",
    "LoadBalancers": [
     {
      "ContainerName": "dashboard",
      "ContainerPort": 8501,
      "TargetGroupArn": {
       "Ref": "DashboardTg"
      }
     }
    ],
    "NetworkConfiguration": {
     "AwsvpcConfiguration": {
      "AssignPublicIp": "ENABLED",
      "SecurityGroups": [
       {
        "Fn::GetAtt": [
         "TaskSg",
         "GroupId"
        ]
       }
      ],
      "Subnets": [
       {
        "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpcPublicSubnet1SubnetB3F9C79BB7FB4087"
       },
       {
        "Fn::ImportValue": "UrbanStressDatamart:ExportsOutputRefUrbanStressVpcPublicSubnet2Subnet9557769E4F7FA592"
       }
      ]
     }
    },
    "ServiceName": "urban-stress-dashboard",
    "TaskDefinition": {
     "Ref": "DashboardTaskDef"
    }
   },
   "DependsOn": [
    "DashboardListener",
    "DashboardTaskDef"
   ],
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/DashboardService"
   }
  },
  "CDKMetadata": {
   "Type": "AWS::CDK::Metadata",
   "Properties": {
    "Analytics": "v2:deflate64:H4sIAAAAAAAA/y2NQQ6CMBBFz+K+VMFwATFxY6IR96aUoY7UlrRTDCHcXSisJu/9+TMZz/KUH3bi5xNZt4nGio8lCdmyWb1GbZXnRWOuVl2cDR0DmS1cggwOadikFp5QaivqSmhhJBrVZ3yMRVGfogPHZn4Kp4DW2hKjJzDgpvmwj4VCh1ltu749Q4MGCa1h8a3rUcI0LXAL1AWa2H2gtzX7I09Tnu8+HjFxwRB+gT/W+Qecm4LL5gAAAA=="
   },
   "Metadata": {
    "aws:cdk:path": "UrbanStressDashboard/CDKMetadata/Default"
   }
  }
 },
 "Outputs": {
  "DashboardUrl": {
   "Value": {
    "Fn::Sub": [
     "http://${AlbDns}",
     {
      "AlbDns": {
       "Fn::GetAtt": [
        "DashboardAlb",
        "DNSName"
       ]
      }
     }
    ]
   },
   "Export": {
    "Name": "UrbanStress-DashboardUrl"
   }
  },
  "EcrRepoUri": {
   "Value": "677542194461.dkr.ecr.us-east-1.amazonaws.com/urban-stress-dashboard",
   "Export": {
    "Name": "UrbanStress-EcrRepoUri"
   }
  }
 }
}